# Stripe -- set in Vercel Project Settings -> Environment Variables.
# The Vercel Stripe integration populates STRIPE_SECRET_KEY and
# STRIPE_PUBLISHABLE_KEY automatically; you add the webhook secret yourself
# after creating the webhook endpoint in the Stripe Dashboard.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: override the default Formspree endpoint used by the webhook.
# Defaults to the same endpoint the application form uses (mbdzblrb).
# FORMSPREE_VENDOR_URL=https://formspree.io/f/your_vendor_form_id

# Sponsor interest form endpoint used by the client-side sponsor form.
VITE_FORMSPREE_SPONSOR_URL=https://formspree.io/f/your_sponsor_form_id
